{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node servers.js",
    "dev": "cross-env NODE_ENV=development nodemon servers.js",
    "test": "cross-env NODE_ENV=test node servers.js",
    "db:create": "sequelize-cli db:create",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:undo": "sequelize-cli db:migrate:undo",
    "db:setup": "npm run db:create && npm run db:migrate",
    "db:create:dev": "cross-env NODE_ENV=development sequelize-cli db:create",
    "db:migrate:dev": "cross-env NODE_ENV=development sequelize-cli db:migrate",
    "db:seed:dev": "cross-env NODE_ENV=development sequelize-cli db:seed:all",
    "db:create:test": "cross-env NODE_ENV=test sequelize-cli db:create",
    "db:migrate:test": "cross-env NODE_ENV=test sequelize-cli db:migrate",
    "db:seed:test": "cross-env NODE_ENV=test sequelize-cli db:seed:all",
    "db:migrate:prod": "cross-env NODE_ENV=production sequelize-cli db:migrate",
    "db:seed:prod": "cross-env NODE_ENV=production sequelize-cli db:seed:all"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "pg": "^8.17.2",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.5"
  }
}