# =========================================================
# Orange LMS Environment Example
# Copy this file to `.env`, then fill the values you need.
# Do not commit `.env` because it contains secrets.
# =========================================================

# 1. Server / App Config
PORT=5000
APP_NAME=OrangeLMS

# NODE_ENV is usually set by npm scripts:
# - npm run dev              -> development
# - npm run test             -> test
# - npm start                -> production
# - npm run db:migrate:prod  -> production migration
NODE_ENV=development

# 2. PostgreSQL Database - Development / Local
# Used when NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=orange-lms-server

# 3. PostgreSQL Database - Testing
# Used when NODE_ENV=test
# This project reads DB_NAME_TEST for test database name.
DB_NAME_TEST=orange-lms-server-test

# 4. PostgreSQL Database - Production / Supabase
# Used when NODE_ENV=production
#
# Option A:
# Fill DATABASE_URL from Supabase Dashboard -> Connect.
# Recommended for Render deployment.
#
# Option B:
# Leave DATABASE_URL empty and use DB_HOST, DB_PORT,
# DB_USER, DB_PASSWORD, and DB_NAME_PROD instead.
DB_NAME_PROD=postgres
DB_SSL=false
DATABASE_URL=

# Example Supabase direct connection:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DB_SSL=true

# 5. Authentication
JWT_SECRET=bebas
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# 6. Cloudinary Upload
CLOUDINARY_CLOUD_NAME=dfdlmc6vs
CLOUDINARY_API_KEY=861132368469594
CLOUDINARY_API_SECRET=dl81ulzQtFOTlVjubgiLgHTRoaY
CLOUDINARY_API=CLOUDINARY_URL=cloudinary://861132368469594:dl81ulzQtFOTlVjubgiLgHTRoaY@dfdlmc6vs
